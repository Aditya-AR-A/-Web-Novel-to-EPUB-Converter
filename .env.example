# Core database configuration
MONGO_URI=mongodb://localhost:27017/webnovel

# Optional: override local output directories
# BOOKS_DIR=/absolute/path/to/books
# MEDIA_DIR=/absolute/path/to/media

# Cloudflare R2 configuration
# Fill these with the credentials from your Cloudflare dashboard.
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ACCOUNT_ID=
R2_BUCKET=webnovel
R2_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com/webnovel
# If you serve objects via a custom domain, set the public base URL below.
# Otherwise leave it blank to use the endpoint as the download base.
R2_PUBLIC_BASE_URL=
R2_REGION=auto

# ============== MEGA Cloud Storage ==============
# MEGA credentials (optional, for storing manga images in MEGA cloud)
# Create a free account at https://mega.nz for 50GB storage
# Images are uploaded to /manga/{manga_key}/ch_{chapter}/ folders
MEGA_EMAIL=
MEGA_PASSWORD=
